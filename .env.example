# Copy to .env and fill in real values. Never commit .env to git.
#
# Hostnames below (redis, postgres) match Docker Compose service names on the
# internal network. Use localhost only when running Go outside Docker.

REDIS_ADDR=redis:6379
# Optional; leave empty for local/dev Redis without auth
REDIS_PASSWORD=
POSTGRES_DSN=postgres://admin:password@postgres:5432/monitor_db?sslmode=disable
WORKER_COUNT=10

# HTTP listen address for the Go API (default :8080).
# LISTEN_ADDR=:8080

# How often (seconds) the feeder re-queues every monitor from Postgres (default 30).
FEED_INTERVAL_SEC=30
# How often (seconds) the flusher drains Redis ping_buffer into Postgres (default 10).
FLUSH_INTERVAL_SEC=10

# Delete ping_results older than this many days (default 30). Set to 0 to disable.
PING_RETENTION_DAYS=30
# How often (seconds) the retention job runs (default 86400 = once per day).
RETENTION_CLEANUP_INTERVAL_SEC=86400

# Optional overrides (defaults match Gmail)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=monitor_db

# Prometheus metrics collector gauge refresh (seconds, default 15).
# METRICS_COLLECT_INTERVAL_SEC=15

# Grafana login (docker-compose grafana service, http://127.0.0.1:3001)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
